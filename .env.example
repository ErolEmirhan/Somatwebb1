# İsteğe bağlı: Boş bırakırsanız src/config/firebase.js içindeki varsayılanlar kullanılır (Vercel’de .env gerekmez).
# Farklı Firebase projesi için burayı doldurun.

# Firebase (Vite: VITE_ öneki)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Menü (öncelik sırası):
# 1) categories + products — kategori başlığı / kapak + ürünler (category_id ile bağlı)
VITE_FIREBASE_CATEGORIES_COLLECTION=categories
VITE_FIREBASE_PRODUCTS_COLLECTION=products

# 2) Tek belge: collectionId/documentId — belgede `panels` (dizi)
# VITE_FIREBASE_MENU_ROOT_DOC=config/menu

# 3) Her belge bir panel
# VITE_FIREBASE_MENU_PANELS_COLLECTION=menu_panels
