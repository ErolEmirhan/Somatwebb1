# ÖNEMLİ — Vercel / Netlify: Bu dosya repoya gider; GERÇEK değerleri sadece hosting
# "Environment Variables" paneline yapıştırın (.env gitignore’da kalır).
# VITE_FIREBASE_* production’da yoksa Firestore bağlanmaz; ürün görselleri menüde/hero’da GÖRÜNMEZ
# (yerel menuData’da gömülü görsel yok, görseller veritabanından gelir).

# Firebase (Vite: VITE_ öneki zorunlu)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Menü (öncelik sırası):
# 1) categories + products — kategori başlığı / kapak + ürünler (category_id ile bağlı)
VITE_FIREBASE_CATEGORIES_COLLECTION=categories
VITE_FIREBASE_PRODUCTS_COLLECTION=products

# 2) Tek belge: collectionId/documentId — belgede `panels` (dizi)
# VITE_FIREBASE_MENU_ROOT_DOC=config/menu

# 3) Her belge bir panel
# VITE_FIREBASE_MENU_PANELS_COLLECTION=menu_panels
